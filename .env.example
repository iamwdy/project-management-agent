# Copy this file to .env and fill in only the variables needed by this project.
# Never commit real secrets. Keep tokens in local env or a secret manager.

# App settings
APP_ENV=development
LOG_LEVEL=info

# Asana
ASANA_PAT=YOUR_ASANA_PAT
ASANA_WORKSPACE_GID=
ASANA_PROJECT_GID=1211031887419620
ASANA_PORTFOLIO_GID=

# Notion
NOTION_TOKEN=YOUR_NOTION_TOKEN
NOTION_PAGE_ID=
NOTION_SOURCE_DB_ID=
NOTION_TARGET_DB_ID=

# Sync behavior
DEFAULT_TIMEZONE=Asia/Taipei
SYNC_DRY_RUN=true
SYNC_BATCH_SIZE=50

# Manual communication intake
INTAKE_SOURCE_TYPE=manual
INTAKE_DEFAULT_OWNER=
INTAKE_DEFAULT_CHANNEL=personal-chat
